# Node from .node-version via nvm (use_nvm helper in ~/.config/direnv/direnvrc)
# — puts node 24 on PATH for make, editors, and git hooks, not just login shells.
use nvm

# Local node_modules/.bin on PATH so installed CLIs work without `npx`
PATH_add "$PWD/node_modules/.bin"

# Load secrets from .env if present (gitignored)
dotenv_if_exists
