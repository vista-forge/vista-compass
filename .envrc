# Local node_modules/.bin on PATH so installed CLIs work without `npx`
PATH_add "$PWD/node_modules/.bin"

# Pin Node version to .node-version (works with nvm/asdf if `direnv-nvm` plug-in
# is installed; harmless otherwise — `npm install` still picks up `engines`).

# Load secrets from .env if present (gitignored)
dotenv_if_exists
