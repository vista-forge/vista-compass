{
  "name": "vista-compass",
  "version": "0.3.0",
  "description": "Vista Compass \u2014 VSCode extension over the vista-meta data release (meta.db): call graph, PIKS, RPCs/options/protocols, package topology, XINDEX. What the system measurably IS.",
  "type": "module",
  "main": "./dist/extension.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "contracts",
    "images",
    "language-configuration.json",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=24",
    "vscode": "^1.125.0"
  },
  "scripts": {
    "test": "node --import tsx --test 'src/**/*.test.ts'",
    "test:watch": "node --import tsx --test --watch 'src/**/*.test.ts'",
    "test:cov": "c8 --reporter=text --reporter=lcov node --import tsx --test 'src/**/*.test.ts'",
    "lint": "biome check src/",
    "format": "biome format --write src/",
    "fix": "biome check --write src/",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "audit": "npm audit --audit-level=high",
    "check": "npm run lint && npm run typecheck && npm run test:cov && npm run audit && npm run bundle",
    "prepublishOnly": "npm run build",
    "bundle": "esbuild src/ext/extension.ts --bundle --outfile=dist/extension.cjs --external:vscode --platform=node --format=cjs --sourcemap",
    "bundle:smoke": "esbuild src/smoke/suite.ts --bundle --outfile=dist/smoke-suite.cjs --external:vscode --platform=node --format=cjs",
    "test:vscode": "npm run bundle && npm run bundle:smoke && node --import tsx src/smoke/run.ts",
    "vscode:prepublish": "npm run bundle",
    "vsix": "vsce package --no-dependencies"
  },
  "license": "MIT",
  "author": "Rafael Richards",
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@types/node": "^26.1.0",
    "@types/vscode": "^1.125.0",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.9.2",
    "c8": "^11.0.0",
    "esbuild": "^0.28.1",
    "simple-git-hooks": "^2.11.1",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3"
  },
  "simple-git-hooks": {
    "pre-commit": "npm run lint && npm run typecheck",
    "pre-push": "npm run test:cov"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vista-forge/vista-compass"
  },
  "displayName": "Vista Compass",
  "publisher": "vista-forge",
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:**/*.m",
    "onLanguage:mumps"
  ],
  "contributes": {
    "views": {
      "explorer": [
        {
          "id": "vistaCompassRoutine",
          "name": "VistA Routine",
          "icon": "$(compass)"
        }
      ]
    },
    "commands": [
      {
        "command": "vistaCompass.refresh",
        "title": "VistA Compass: Refresh Routine Sidebar",
        "icon": "$(refresh)"
      },
      {
        "command": "vistaCompass.reloadData",
        "title": "VistA Compass: Reload Data (re-verify release)"
      },
      {
        "command": "vistaCompass.findRpc",
        "title": "VistA Compass: Find RPC"
      },
      {
        "command": "vistaCompass.findOption",
        "title": "VistA Compass: Find Option"
      },
      {
        "command": "vistaCompass.packageDashboard",
        "title": "VistA Compass: Package Dashboard"
      },
      {
        "command": "vistaCompass.search",
        "title": "VistA Compass: Search Measured Model"
      },
      {
        "command": "vistaCompass.findInDocs",
        "title": "VistA Compass: Find in Docs (Vista Atlas)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "vistaCompass.refresh",
          "when": "view == 'vistaCompassRoutine'",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "vistaCompass.findInDocs",
          "when": "resourceExtname == '.m'",
          "group": "navigation"
        }
      ]
    },
    "languages": [
      {
        "id": "mumps",
        "aliases": [
          "MUMPS",
          "M"
        ],
        "extensions": [
          ".m"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "configuration": {
      "title": "Vista Compass",
      "properties": {
        "vistaCompass.dataPath": {
          "type": "string",
          "default": "",
          "description": "Path to a local meta.db (vista-meta-data-v1.db). Empty: fetch-verify the published release into global storage."
        },
        "vistaCompass.vistaMHostPath": {
          "type": "string",
          "default": "",
          "description": "Host directory mirroring the container /opt/VistA-M tree (e.g. ~/projects/vista-meta/vista/vista-m-host) \u2014 enables click-to-open on callers/callees."
        },
        "vistaCompass.topN": {
          "type": "number",
          "default": 15,
          "description": "Maximum entries per sidebar section."
        },
        "vistaCompass.xindexAsDiagnostics": {
          "type": "boolean",
          "default": false,
          "description": "Surface XINDEX findings in the Problems panel and editor gutter."
        }
      }
    }
  },
  "icon": "images/icon.png"
}
